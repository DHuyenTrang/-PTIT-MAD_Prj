<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="68dp" />
            <gradient
                android:type="linear"
                android:angle="0"
            android:startColor="#FFC7AD82"
            android:centerColor="#FFF1E6D2"
            android:endColor="#FFCFB585" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="66dp" />
            <solid android:color="#FF000000" />
        </shape>
    </item>

</layer-list>
