<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dayItem"
    android:layout_width="wrap_content"
    android:layout_height="96dp"
    android:layout_weight="1"
    android:minWidth="40dp">

    <LinearLayout
        android:id="@+id/layoutDayInWeek"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@+id/layoutDay"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/txtDayInWeek"
            style="@style/Gofa.TextBase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="T2"
            android:textColor="@color/onSurface" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutDay"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutDayInWeek">

        <TextView
            android:id="@+id/txtDay"
            style="@style/Gofa.TextBase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="28"
            android:textAlignment="center"
            android:textColor="@color/onSurface" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
