<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutRootView"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_route_card_unselected"
    android:orientation="vertical"
    android:padding="@dimen/padding_route_option">

    <TextView
        android:id="@+id/txtDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/base_content_margin_title"
        android:autoSizeTextType="uniform"
        android:maxLines="1"
        android:textAppearance="@style/Gofa.TextBase.Bold.LineHeight"
        android:textColor="@color/primary"
        android:textFontWeight="600"
        tools:text="10 phút (6 km)" />

    <TextView
        android:id="@+id/txtDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:autoSizeTextType="uniform"
        android:textAppearance="@style/Gofa.TextXs.LineHeight"
        android:textColor="@color/onSurfaceVariant"
        android:textFontWeight="400"
        tools:text="Đường tốt nhất" />

</LinearLayout>
