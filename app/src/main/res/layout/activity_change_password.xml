<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".ui.setting.ChangePasswordActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="@dimen/activity_padding_horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cancel"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/change_password"
                android:textAppearance="@style/Gofa.TextLg.Bold" />
        </RelativeLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/activity_padding_horizontal"
            android:paddingTop="24dp">

            <!-- Current Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_password"
                android:textAppearance="@style/Gofa.TextSm"
                android:textColor="@color/onSurfaceVariant" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputCurrentPassword"
                style="@style/Gofa.TextField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/current_password"
                app:endIconMode="password_toggle"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCurrentPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textAppearance="@style/Gofa.TextBase"
                    android:textColor="@color/onSurfaceVariant" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/txtCurrentPasswordError"
                style="@style/Gofa.TextSm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:drawableStart="@drawable/ic_info"
                android:drawablePadding="4dp"
                android:drawableTint="@color/error"
                android:gravity="center_vertical"
                android:textColor="@color/error"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- New Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/new_password"
                android:textAppearance="@style/Gofa.TextSm"
                android:textColor="@color/onSurfaceVariant" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputNewPassword"
                style="@style/Gofa.TextField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/new_password"
                app:endIconMode="password_toggle"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textAppearance="@style/Gofa.TextBase"
                    android:textColor="@color/onSurfaceVariant" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/txtNewPasswordError"
                style="@style/Gofa.TextSm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:drawableStart="@drawable/ic_info"
                android:drawablePadding="4dp"
                android:drawableTint="@color/error"
                android:gravity="center_vertical"
                android:textColor="@color/error"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Confirm New Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/confirm_new_password"
                android:textAppearance="@style/Gofa.TextSm"
                android:textColor="@color/onSurfaceVariant" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputConfirmPassword"
                style="@style/Gofa.TextField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/confirm_new_password"
                app:endIconMode="password_toggle"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textAppearance="@style/Gofa.TextBase"
                    android:textColor="@color/onSurfaceVariant" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/txtConfirmPasswordError"
                style="@style/Gofa.TextSm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:drawableStart="@drawable/ic_info"
                android:drawablePadding="4dp"
                android:drawableTint="@color/error"
                android:gravity="center_vertical"
                android:textColor="@color/error"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSavePassword"
                style="@style/Gofa.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:text="@string/save_password" />

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>
