<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_marginTop="40dp"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/trHeader"
            android:paddingHorizontal="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <com.google.android.material.button.MaterialButton
                style="@style/Gofa.IconButton.Outline"
                app:icon="@drawable/ic_back"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:id="@+id/ivBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"/>
            <TextView
                android:layout_marginBottom="2dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="20dp"
                android:text="@string/saved"
                android:textAppearance="@style/Gofa.TextXL.Bold.LineHeight"
                android:textSize="18sp"
                android:textColor="@color/onSurfaceVariant"
                android:layout_gravity="center_vertical"/>

            <androidx.appcompat.widget.AppCompatImageView
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:id="@+id/ivEdit"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_pen_edit"
                android:layout_marginEnd="8dp"
                android:paddingVertical="12dp" />
            <com.google.android.material.button.MaterialButton
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                style="@style/Gofa.Button"
                android:layout_marginEnd="20dp"
                android:id="@+id/btnDone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/done"
                android:layout_gravity="center_vertical"
                android:visibility="gone"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            android:id="@+id/llHeader"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/bg_saved_place"
            app:layout_constraintTop_toBottomOf="@id/trHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TableRow
                android:id="@+id/tbEditHome"
                android:layout_marginVertical="12dp"
                android:layout_marginStart="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_gravity="center_vertical"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_house_line"/>
                <LinearLayout
                    android:layout_marginStart="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_weight="1">
                    <TextView
                        android:id="@+id/tvHome"
                        android:layout_width="match_parent"
                        android:layout_height="24dp"
                        android:text="Nhà"
                        android:textAppearance="@style/Gofa.TextBase"
                        android:textSize="16sp"
                        android:textColor="@color/onSurface"/>
                    <TextView
                        android:id="@+id/tvHomeName"
                        android:layout_width="match_parent"
                        android:layout_height="24dp"
                        android:text="Cài đặt vị trí"
                        android:textAppearance="@style/Gofa.TextSm"
                        android:textSize="14sp"
                        android:textColor="@color/primary"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditHome"
                    style="@style/Gofa.IconButton.Outline"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center_vertical"
                    android:padding="12dp"
                    app:icon="@drawable/ic_navigation_right" />
            </TableRow>
            <View
                android:layout_width="match_parent"
                android:layout_marginStart="52dp"
                android:layout_gravity="end"
                android:layout_height="1dp"
                android:background="@color/outlineVariant"/>
            <TableRow
                android:id="@+id/tbEditWorkPlace"
                android:layout_marginVertical="12dp"
                android:layout_marginStart="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_gravity="center_vertical"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_bag"/>
                <LinearLayout
                    android:layout_marginStart="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_weight="1">
                    <TextView
                        android:id="@+id/tvWorkPlace"
                        android:layout_width="match_parent"
                        android:layout_height="24dp"
                        android:text="Cơ quan"
                        android:textAppearance="@style/Gofa.TextBase"
                        android:textSize="16sp"
                        android:textColor="@color/onSurface"/>
                    <TextView
                        android:id="@+id/tvWorkPlaceName"
                        android:layout_width="match_parent"
                        android:layout_height="24dp"
                        android:text="Cài đặt vị trí"
                        android:textAppearance="@style/Gofa.TextSm"
                        android:textSize="14sp"
                        android:textColor="@color/primary"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditWorkPlace"
                    style="@style/Gofa.IconButton.Outline"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="12dp"
                    android:layout_gravity="center_vertical"
                    app:icon="@drawable/ic_navigation_right" />
            </TableRow>
        </LinearLayout>
        <LinearLayout
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/bg_saved_place"
            app:layout_constraintTop_toBottomOf="@id/llHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TableRow
                android:id="@+id/tbAddLocation"
                android:layout_marginVertical="12dp"
                android:layout_marginStart="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_gravity="center_vertical"
                    android:tint="@color/primary"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_plus"/>
                <LinearLayout
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_weight="1">
                    <TextView
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Thêm địa điểm"
                        android:textAppearance="@style/Gofa.TextBase.Bold"
                        android:textSize="16sp"
                        android:textColor="@color/primary"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddLocation"
                    style="@style/Gofa.IconButton.Outline"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="12dp"
                    android:layout_gravity="center_vertical"
                    app:icon="@drawable/ic_navigation_right" />
            </TableRow>
            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/rycSaveLocation"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_saved_location"
                tools:itemCount="4"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
