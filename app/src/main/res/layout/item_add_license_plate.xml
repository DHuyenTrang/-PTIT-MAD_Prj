<?xml version="1.0" encoding="utf-8"?>

    <androidx.appcompat.widget.LinearLayoutCompat
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/llAddLicensePlate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <TextView
            android:id="@+id/tvDeleteLicensePlate"
            android:textAllCaps="true"
            android:layout_width="237dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:background="@drawable/bg_search_fine"
            android:drawableStart="@drawable/ic_car"
            android:drawablePadding="12dp"
            android:padding="9dp"
            android:text="30G-12345"
            android:maxLength="10"
            android:textAppearance="@style/Gofa.TextBase"
            android:textColor="@color/onSurface" />

        <androidx.appcompat.widget.AppCompatButton
            android:layout_marginEnd="2dp"
            android:layout_marginBottom="2dp"
            android:layout_marginTop="2dp"
            android:layout_marginStart="16dp"
            android:id="@+id/btnDeleteLicensePlate"
            android:background="@drawable/bg_button_error_container"
            android:gravity="center"
            android:textColor="@color/onErrorContainer"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textAppearance="@style/Gofa.TextBase.Bold"
            android:layout_marginLeft="16dp"
            android:text="@string/delete_fine_button_title" />
    </androidx.appcompat.widget.LinearLayoutCompat>