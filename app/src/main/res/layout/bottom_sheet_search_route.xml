<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:theme="@style/Theme.Gofa"
    android:orientation="vertical"
    android:paddingBottom="@dimen/bottom_sheet_padding_vertical"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">


    <LinearLayout
        android:id="@+id/pullBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:background="@drawable/drag_container"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/llSearchBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--Search bar header-->
    <LinearLayout
        android:id="@+id/llSearchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/activity_padding_horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pullBar">

        <EditText
            android:id="@+id/search_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_gofa_search_bar"
            android:drawablePadding="@dimen/search_bar_padding"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:hint="@string/search_address"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLength="@integer/search_max_length"
            android:maxLines="1"
            android:paddingHorizontal="@dimen/search_bar_padding"
            android:textAppearance="@style/Gofa.TextBase"
            android:textColor="@color/onSurfaceVariant"
            android:textColorHint="@color/onSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            style="@style/Gofa.IconButton.Outline"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:visibility="visible"
            app:icon="@drawable/ic_cancel"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />
    </LinearLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:itemCount="2"
        tools:listitem="@layout/item_search_place_result" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/groupSearchRecent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <com.n3t.mobile.ui.search.widgets.PlaceTypeSession
            android:id="@+id/widget_session_place_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <com.n3t.mobile.core.widgets.GofaCellCustom
            android:id="@+id/layoutMyLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/activity_padding_horizontal"
            android:layout_marginTop="16dp"
            app:borderType="all"
            app:icon="@drawable/ic_location"
            app:isActiveInCell="true"
            app:title="@string/my_location_expand" />

        <TextView
            android:id="@+id/tvRecent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/activity_padding_horizontal"
            android:layout_marginTop="16dp"
            android:text="@string/recent"
            android:textAppearance="@style/Gofa.TextBase.Bold.LineHeight" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecentPlace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:itemCount="1"
            tools:listitem="@layout/item_search_place_recent" />


    </androidx.appcompat.widget.LinearLayoutCompat>

    <View
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
