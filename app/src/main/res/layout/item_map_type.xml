<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:src="@drawable/type_map4d"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:padding="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/img_type"
        android:scaleType="centerCrop"
        />
    <TextView
        android:id="@+id/tv_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bản đồ 4D"
        android:textAppearance="@style/Gofa.TextXs"
        app:layout_constraintTop_toBottomOf="@id/img_type"
        app:layout_constraintStart_toStartOf="@id/img_type"
        app:layout_constraintEnd_toEndOf="@id/img_type"
        android:layout_marginTop="@dimen/bottom_sheet_padding_vertical" />
    <View
        android:id="@+id/view_selected"
        android:layout_width="84dp"
        android:layout_height="84dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/bg_map_type_selected"
        android:visibility="gone"
        />
</androidx.constraintlayout.widget.ConstraintLayout>
