<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="12dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@+id/divider"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_width="match_parent"
        android:layout_marginStart="52dp"
        android:layout_gravity="end"
        android:layout_height="1dp"
        android:background="@color/outlineVariant"/>
    <TableRow
        android:id="@+id/tbSeeAll"
        app:layout_constraintTop_toBottomOf="@+id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginVertical="12dp"
        android:layout_marginStart="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivIcon"
            android:layout_gravity="center_vertical"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_bag"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1">
            <TextView
                android:id="@+id/tvNamePlace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cơ quan"
                android:textAppearance="@style/Gofa.TextBase"
                android:textSize="16sp"
                android:textColor="@color/onSurface"/>
            <TextView
                android:id="@+id/tvNameLocation"
                android:layout_width="match_parent"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Gofa.TextSm"
                android:textSize="14sp"
                android:textColor="@color/onSurfaceVariant"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeeAll"
            style="@style/Gofa.IconButton.Outline"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="12dp"
            android:layout_gravity="center_vertical"
            app:icon="@drawable/ic_navigation_right" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeletePlace"
            style="@style/Gofa.IconButton.Error"
            android:layout_width="54dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical"
            app:icon="@drawable/ic_minuscircle" />

    </TableRow>
</androidx.constraintlayout.widget.ConstraintLayout>
