<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_recyclerview"
    android:layout_width="295dp"
    android:layout_height="wrap_content"
    android:layout_marginRight="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/card_padding"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_margin="@dimen/card_padding"
                android:src="@drawable/bg_avatar"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/card_padding"
                android:layout_marginRight="@dimen/card_padding"
                android:text="Name"
                android:textAppearance="@style/Gofa.TextSm.Bold"
                android:textColor="@color/onSurface"
                app:layout_constraintLeft_toRightOf="@+id/ivAvatar"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/card_padding"
                android:text="10 minutes ago"
                android:textAppearance="@style/Gofa.TextXs"
                android:textColor="@color/onSurfaceVariant"
                app:layout_constraintLeft_toLeftOf="@+id/tvName"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvName" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:ellipsize="end"
            android:layout_marginEnd="12dp"
            android:maxLines="1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/card_padding"
            android:layout_marginTop="@dimen/card_padding"
            android:text="News title"
            android:textAppearance="@style/Gofa.TextSm.Bold.LineHeight"
            android:textColor="@color/onSurface"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutHeader" />

        <TextView
            android:id="@+id/tvLink"
            android:ellipsize="end"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/card_padding"
            android:text="News content"
            android:layout_marginEnd="12dp"
            android:maxLines="1"
            android:textAppearance="@style/Gofa.TextSm.LineHeight"
            android:textColor="@color/primary"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTitle" />
        <TableRow
            android:id="@+id/trImage"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvLink"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/ivImage1"
                android:layout_width="161dp"
                android:layout_height="162dp"
                android:src="@drawable/default_placeholder_1"/>
            <LinearLayout
                android:layout_marginStart="2dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/ivImage2"
                    android:layout_width="132dp"
                    android:layout_height="80dp"
                    android:src="@drawable/default_placeholder_1"
                    android:scaleType="centerCrop"/>
                <ImageView
                    android:id="@+id/ivImage3"
                    android:layout_marginTop="2dp"
                    android:layout_width="132dp"
                    android:layout_height="80dp"
                    android:src="@drawable/default_placeholder_1"
                    android:scaleType="centerCrop"/>
            </LinearLayout>
        </TableRow>
        <TableRow
            android:layout_marginTop="20dp"
            android:id="@+id/trEmoji"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/trImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageView
                android:layout_marginStart="12dp"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_thumb_up"
                android:padding="4dp"/>
            <TextView
                android:id="@+id/tvLikeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="32"
                android:layout_gravity="center_vertical"
                android:textAppearance="@style/Gofa.TextSm.Bold"
                android:textSize="14sp"
                android:textColor="@color/onSurfaceVariant"/>
            <ImageView
                android:layout_marginStart="20dp"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_chat_dot"
                android:padding="4dp"/>
            <TextView
                android:id="@+id/tvChatCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:layout_gravity="center_vertical"
                android:textAppearance="@style/Gofa.TextSm.Bold"
                android:textSize="14sp"
                android:textColor="@color/onSurfaceVariant"/>
        </TableRow>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
