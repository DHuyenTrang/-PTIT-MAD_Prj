<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="@dimen/bottom_sheet_padding_vertical"
    app:behavior_peekHeight="@dimen/peek_height_bottom_sheet_dashboard"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="8dp"
                android:background="@drawable/drag_container" />

            <!--Search bar header-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/activity_padding_horizontal">

                <TextView
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:id="@+id/search_bar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/search_bar_padding"
                    android:layout_weight="1"
                    android:background="@drawable/bg_gofa_search_bar"
                    android:drawableStart="@drawable/ic_magnifying"
                    android:drawablePadding="@dimen/search_bar_padding"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/search_bar_padding"
                    android:text="@string/search_address"
                    android:textAppearance="@style/Gofa.TextBase"
                    android:textColorHint="@color/onSurfaceVariant"
                    android:textColor="@color/onSurfaceVariant" />

                <com.n3t.mobile.core.widgets.CircleIconButton
                    android:id="@+id/btnSetting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:size="50dp"
                    app:iconSize="20dp"
                    app:icon="@drawable/ic_setting"
                    app:isColorIcon="true"
                    />
            </LinearLayout>

            <!--Favorite address-->
            <com.n3t.mobile.ui.search.widgets.PlaceTypeSession
                android:id="@+id/widget_session_place_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp" />

            <!--Tra cứu phạt nguội-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_coordinator_layout"
                android:background="@color/surfaceContainer"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="16dp"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:text="TRA CỨU PHẠT NGUỘI"
                    android:textAppearance="@style/Gofa.TextXs.Bold"
                    android:textColor="@color/onSurfaceVariant" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!--TODO: Replace with exact Warning Drawable later if needed -->
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:tint="@color/warning" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Chưa có biển số"
                        android:textAppearance="@style/Gofa.TextSm.Bold"
                        android:textColor="@color/onSurface" />

                    <Button
                        android:id="@+id/btnAddPlate"
                        style="@style/Gofa.TextButton.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:layout_marginTop="16dp"
                        android:text="Thêm biển"
                        app:cornerRadius="24dp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="@android:color/transparent" />

            <!--Lịch sử di chuyển-->
            <LinearLayout
                android:id="@+id/btnTravelHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surfaceContainer"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/margin_coordinator_layout"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LỊCH SỬ DI CHUYỂN"
                    android:textAppearance="@style/Gofa.TextXs.Bold"
                    android:textColor="@color/onSurfaceVariant" />

                <!-- Dùng text ">" tạm làm icon chevron right nếu chưa có drawable, 
                     anh có thể thay bằng @drawable/ic_chevron_right -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textAppearance="@style/Gofa.TextLg.Bold"
                    android:textColor="@color/primary" />
            </LinearLayout>

        </androidx.appcompat.widget.LinearLayoutCompat>
</LinearLayout>
