<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginVertical="8dp"
        android:background="@drawable/drag_container" />
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="48dp">

        <TextView
            android:id="@+id/tvType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="20dp"
            android:text="Nhà"
            android:textAppearance="@style/Gofa.TextXL.Bold"
            android:textSize="20sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btnClose"
            android:layout_gravity="center_vertical"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_close"
            android:layout_marginEnd="8dp"
            android:padding="12dp"/>
    </TableRow>
    <LinearLayout
        android:layout_marginVertical="12dp"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/bg_saved_place"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TableRow
            android:id="@+id/btnEditHome"
            android:layout_marginVertical="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            >
            <ImageView
                android:layout_marginStart="16dp"
                android:layout_marginEnd="12dp"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_pen_edit"/>
            <TextView
                android:layout_gravity="center_vertical"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:text="Sửa vị trí"
                android:textAppearance="@style/Gofa.TextBase"
                android:textColor="@color/onSurface"
                android:textSize="16sp"/>
            <ImageView
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_navigation_right"/>
        </TableRow>
        <View
            android:layout_width="match_parent"
            android:layout_marginStart="52dp"
            android:layout_gravity="end"
            android:layout_height="1dp"
            android:background="@color/outlineVariant"/>
        <TableRow
            android:id="@+id/btnDeleteLocation"
            android:layout_marginVertical="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            >
            <ImageView
                android:layout_marginStart="16dp"
                android:layout_marginEnd="12dp"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_trash"/>
            <TextView
                android:layout_gravity="center_vertical"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:text="Xóa vị trí"
                android:textAppearance="@style/Gofa.TextBase.Bold"
                android:textColor="@color/error"
                android:textSize="16sp"/>
            <ImageView
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_navigation_right"/>
        </TableRow>
    </LinearLayout>
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnDone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_button"
        android:text="Xong"
        android:textColor="@color/onPrimary"
        android:textAppearance="@style/Gofa.TextBase.Bold"
        android:textSize="16sp"
        android:layout_margin="16dp"/>
</LinearLayout>
